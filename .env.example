# ─── Health, Wand and Fire — Environment Variables ───────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Anthropic API key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server port (optional, default: 3001)
PORT=3001

# Comma-separated browser origins allowed by CORS (e.g. dev client + Vercel URL)
# CORS_ORIGINS=http://localhost:5173,https://your-app.vercel.app
